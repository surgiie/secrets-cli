    echo "$(red_bold [ERROR]): $1"
    if [ ! -z "$exit_code" ]; then
        exit $exit_code
    fi
}

warning(){
    exit_code="${2:-}"
    echo "$(yellow_bold [WARNING]): $1"
    if [ ! -z "$exit_code" ]; then
        exit $exit_code
    fi
}
success(){
    echo "$(green_bold [SUCCESS]): $1"
}
